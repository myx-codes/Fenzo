                        </td>
                    </tr>

                    <tr>
                        <td class="ps-4 fw-bold">#ORD-7720</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-small me-2 bg-light rounded-circle text-center pt-1" style="width:30px; height:30px;">J</div>
                                <span>John Doe</span>
                            </div>
                        </td>
                        <td class="fw-bold">$1,299.00</td>
                        <td class="text-muted small">1 hour ago</td>
                        <td class="text-center">
                            <select class="order-status form-select form-select-sm status-PAID" onchange="changeOrderStatus(this)">
                                <option value="PENDING">PENDING</option>
                                <option value="PAID" selected>PAID</option>
                                <option value="PROCESSING">PROCESSING</option>
                                <option value="SHIPPED">SHIPPED</option>
                                <option value="DELIVERED">DELIVERED</option>
                                <option value="CANCELLED">CANCELLED</option>
                            </select>
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-light border"><i class="fa-solid fa-eye"></i></button>
                        </td>
                    </tr>

                     <tr>
                        <td class="ps-4 fw-bold">#ORD-7719</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-small me-2 bg-light rounded-circle text-center pt-1" style="width:30px; height:30px;">M</div>
                                <span>Malika</span>
                            </div>
                        </td>
                        <td class="fw-bold">$45.00</td>
                        <td class="text-muted small">3 hours ago</td>
                        <td class="text-center">
                            <select class="order-status form-select form-select-sm status-PROCESSING" onchange="changeOrderStatus(this)">
                                <option value="PENDING">PENDING</option>
                                <option value="PAID">PAID</option>
                                <option value="PROCESSING" selected>PROCESSING</option>
                                <option value="SHIPPED">SHIPPED</option>
                                <option value="DELIVERED">DELIVERED</option>
                                <option value="CANCELLED">CANCELLED</option>
                            </select>
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-light border"><i class="fa-solid fa-eye"></i></button>
                        </td>
                    </tr>

                    <tr>
                        <td class="ps-4 fw-bold">#ORD-7715</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-small me-2 bg-light rounded-circle text-center pt-1" style="width:30px; height:30px;">B</div>
