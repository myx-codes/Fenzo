<script>
    function changeOrderStatus(select) {
        // Avvalgi barcha rang klasslarini olib tashlaymiz
        select.classList.remove(
            'status-PENDING', 'status-PAID', 'status-PROCESSING', 
            'status-SHIPPED', 'status-DELIVERED', 'status-CANCELLED', 'status-REFUNDED'
        );
        
        // Yangi tanlangan status klassini qo'shamiz
        const newStatus = select.value;
        select.classList.add('status-' + newStatus);
        
        // Bu yerda keyinchalik AXIOS request yuboriladi
        console.log(`Order updated to: ${newStatus}`);
    }
</script>

