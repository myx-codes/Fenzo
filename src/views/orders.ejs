<%- include('includes/header') %>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/orders.css">

<div class="container py-5">
    <%- include('includes/dashboard-header', {
        activeTab: 'orders',
        user: user
    }) %>

    <form action="/seller/orders" method="GET">
        <div class="panel mb-4 p-3">
            <div class="row g-3">
                
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fa-solid fa-magnifying-glass text-muted"></i>
                        </span>
                        <input type="text" 
                               name="search" 
                               value="<%= locals.search || '' %>" 
                               class="form-control bg-light border-start-0" 
                               placeholder="Order ID, Buyer name...">
                    </div>
                </div>
                
                <div class="col-md-3">
                    <select class="form-select bg-light" name="orderStatus">
                        <option value="">All Statuses</option>
                        <option value="PENDING" <%= locals.orderStatus === 'PENDING' ? 'selected' : '' %>>Pending</option>
                        <option value="PROCESSING" <%= locals.orderStatus === 'PROCESSING' ? 'selected' : '' %>>Processing</option>
                        <option value="SHIPPED" <%= locals.orderStatus === 'SHIPPED' ? 'selected' : '' %>>Shipped</option>
                        <option value="DELIVERED" <%= locals.orderStatus === 'DELIVERED' ? 'selected' : '' %>>Delivered</option>
                        <option value="CANCELLED" <%= locals.orderStatus === 'CANCELLED' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                
                <div class="col-md-3">
                    <input type="date" name="date" class="form-control bg-light">
                </div>
                
                <div class="col-md-2 text-end">
                    <button type="submit" class="btn btn-outline-dark w-100 fw-bold">Search</button>
                </div>
            </div>
        </div>
    </form>

    <div class="panel p-0 overflow-hidden">
        
        <% if(!orders || orders.length === 0) { %>
            <div class="text-center py-5">
                <i class="fa-solid fa-box-open fa-3x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">No orders found</h5>
                <p class="text-muted small">Try adjusting your search criteria.</p>
            </div>
        <% } else { %>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="py-3 ps-4 text-uppercase" style="font-size:14px; letter-spacing:0.5px;">Order Info</th>
                        <th class="py-3 text-uppercase" style="font-size:14px; letter-spacing:0.5px;">Products</th>
                        <th class="py-3 text-uppercase" style="font-size:14px; letter-spacing:0.5px;">Total Amount</th>
                        <th class="py-3 text-uppercase" style="font-size:14px; letter-spacing:0.5px;">Date</th>
                        <th class="py-3 text-center text-uppercase" style="font-size:14px; letter-spacing:0.5px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(function(order, index) { %>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle bg-primary-subtle text-primary me-3 fw-bold" 
                                     style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <%= order.buyerData && order.buyerData.userNick ? order.buyerData.userNick.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">
                                        <%= order.buyerData ? (order.buyerData.userNick || 'Deleted User') : 'Deleted User' %>
                                    </h6>
                                    <small class="text-muted">#<%= order._id.toString().slice(-6).toUpperCase() %></small>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="d-flex flex-column gap-2">
                                <% 
                                const items = order.orderItems || [];
                                if(items.length > 0) { 
                                    items.forEach((item) => { 
                                        const product = item.product || {};
                                        const images = product.productImages || [];
                                        const firstImage = images[0] || '';
                                        const productName = product.productName || 'Unknown Product';
                                %>
                                <div class="d-flex align-items-center">
                                    <% if(firstImage) { %>
                                        <img src="/<%= firstImage %>" 
                                             class="rounded border me-2" 
                                             style="width: 35px; height: 35px; object-fit: cover;">
                                    <% } else { %>
                                        <div class="rounded border me-2 d-flex align-items-center justify-content-center bg-light text-muted"
                                             style="width: 35px; height: 35px;">
                                            <i class="fa-solid fa-image fa-xs"></i>
                                        </div>
                                    <% } %>
                                    <div>
                                        <div class="text-dark small fw-medium"><%= productName %></div>
                                        <div class="text-muted" style="font-size: 11px;">
                                            x<%= item.itemQuantity %>
                                        </div>
                                    </div>
                                </div>
                                <% }) } else { %>
                                    <span class="text-muted small">No items</span>
                                <% } %>
                            </div>
                        </td>

                        <td>
                            <div class="fw-bold text-dark">$<%= order.orderTotal?.toFixed(2) || '0.00' %></div>
                            <% if(order.orderDelivery > 0) { %>
                                <div class="text-muted" style="font-size: 11px;">+ Delivery $<%= order.orderDelivery %></div>
                            <% } %>
                        </td>

                        <td>
                            <span class="text-dark small fw-medium">
                                <%= new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </span>
                            <div class="text-muted" style="font-size: 11px;">
                                <%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                            </div>
                        </td>

                        <td class="text-center">
                            <select class="form-select form-select-sm status-select status-<%= (order.orderStatus || 'PENDING').toLowerCase() %>" 
                                    onchange="updateOrderStatus('<%= order._id %>', this.value)">
                                <option value="PENDING" <%= order.orderStatus === 'PENDING' ? 'selected' : '' %>>PENDING</option>
                                <option value="PROCESSING" <%= order.orderStatus === 'PROCESSING' ? 'selected' : '' %>>PROCESSING</option>
                                <option value="SHIPPED" <%= order.orderStatus === 'SHIPPED' ? 'selected' : '' %>>SHIPPED</option>
                                <option value="DELIVERED" <%= order.orderStatus === 'DELIVERED' ? 'selected' : '' %>>DELIVERED</option>
                                <option value="CANCELLED" <%= order.orderStatus === 'CANCELLED' ? 'selected' : '' %>>CANCELLED</option>
                            </select>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <% if(pagination && pagination.totalPages > 1) { %>
        <div class="position-relative d-flex justify-content-center align-items-center p-3 border-top bg-light"> 
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    
                    <li class="page-item <%= pagination.currentPage <= 1 ? 'disabled' : '' %>">
                        <a class="page-link border-0 bg-transparent" 
                           href="/seller/orders?page=<%= pagination.currentPage - 1 %>&limit=<%= pagination.itemsPerPage %>&orderStatus=<%= locals.orderStatus || '' %>&search=<%= locals.search || '' %>">
                           <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>

                    <% 
                    let startPage = Math.max(1, pagination.currentPage - 2);
                    let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2);
                    
                    for(let i = startPage; i <= endPage; i++) { %>
                    <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
                        <a class="page-link border rounded-2 <%= pagination.currentPage === i ? 'bg-white text-dark shadow-sm fw-bold' : 'bg-transparent text-muted' %> mx-1" 
                           href="/seller/orders?page=<%= i %>&limit=<%= pagination.itemsPerPage %>&orderStatus=<%= locals.orderStatus || '' %>&search=<%= locals.search || '' %>">
                           <%= i %>
                        </a>
                    </li>
                    <% } %>

                    <li class="page-item <%= pagination.currentPage >= pagination.totalPages ? 'disabled' : '' %>">
                        <a class="page-link border-0 bg-transparent" 
                           href="/seller/orders?page=<%= pagination.currentPage + 1 %>&limit=<%= pagination.itemsPerPage %>&orderStatus=<%= locals.orderStatus || '' %>&search=<%= locals.search || '' %>">
                           <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
        <% } %>

        <% } %> </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
    async function updateOrderStatus(id, status) {
        try {
            // Select element rangini o'zgartirish
            const selectElement = document.querySelector(`select[onchange="updateOrderStatus('${id}', this.value)"]`);
            if(selectElement) {
                selectElement.className = `form-select form-select-sm status-select status-${status.toLowerCase()}`;
            }

            // Backendga yuborish
            const response = await axios.post(`/seller/orders/${id}`, { orderStatus: status });
            
            if (response.status === 200) {
                // Muvaffaqiyatli bo'lsa, alert shart emas, rang o'zgardi
                console.log('Status updated');
            }
        } catch (err) {
            console.error(err);
            alert('Failed to update status');
        }
    }
</script>

<%- include('includes/footer') %>