<%- include('includes/header') %>

<link rel="stylesheet" href="/css/dashboard.css">

<div class="container py-5">
    
    <%- include('includes/dashboard-header', {
        activeTab: 'overview',
        user: user
    }) %>

    <div class="row g-3 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Total Revenue</span>
                    <i class="fa-solid fa-dollar-sign metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value">$<%= typeof totalRevenue !== 'undefined' ? Number(totalRevenue).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Total Orders</span>
                    <i class="fa-solid fa-cart-shopping metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value"><%= typeof totalOrders !== 'undefined' ? totalOrders : 0 %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Products Listed</span>
                    <i class="fa-solid fa-box-archive metric-icon"></i>
                </div>
                <div class="mt-2">
                    <h2 class="metric-value"><%= typeof productsCount !== 'undefined' ? productsCount : 0 %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Conversion Rate</span>
                    <i class="fa-solid fa-chart-pie metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value"><%= typeof conversionRate !== 'undefined' ? conversionRate : '0%' %></h2>
                    <span class="badge bg-light text-secondary border ms-2 conversion-badge">Avg</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="panel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="panel-title mb-0">Sales Overview</h5>
                    <select class="form-select form-select-sm w-auto border-0 bg-light">
                        <option>Last 30 Days</option>
                        <option>This Week</option>
                        <option>This Year</option>
                    </select>
                </div>
                
                <% const dayData = typeof salesByDay !== 'undefined' && Array.isArray(salesByDay) ? salesByDay : []; %>
                <div class="chart-placeholder d-flex align-items-end gap-2">
                    <% 
                    let maxRev = 1;
                    for (let i = 0; i < dayData.length; i++) { if (dayData[i].revenue > maxRev) maxRev = dayData[i].revenue; }
                    for (let i = 0; i < dayData.length; i++) { 
                        const d = dayData[i];
                        const pct = Math.round((d.revenue / maxRev) * 100);
                    %>
                    <div class="chart-bar flex-grow-1" style="--bar-height: <%= pct %>%;"></div>
                    <% } %>
                    <% if (dayData.length === 0) { %>
                    <div class="text-muted small align-self-center">No sales data yet</div>
                    <% } %>
                </div>
                <div class="d-flex justify-content-between mt-3 text-muted small">
                    <% for (let i = 0; i < dayData.length; i++) { %>
                    <span><%= dayData[i].date %></span>
                    <% } %>
                    <% if (dayData.length === 0) { %>
                    <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel">
                <h5 class="panel-title">Top Selling Products</h5>
                
                <div class="d-flex flex-column">
                    <% 
                    const products = typeof topProducts !== 'undefined' && Array.isArray(topProducts) ? topProducts : [];
                    products.forEach(function(p) { 
                        const images = p.productImages || [];
                        const firstImage = images[0] || '';
                    %>
                    <div class="product-item">
                        <div class="product-thumb">
                            <% if (firstImage) { %>
                                <img src="/<%= firstImage %>" 
                                     alt="<%= p.productName || 'Product' %>">
                            <% } else { %>
                                <i class="fa-solid fa-box"></i>
                            <% } %>
                        </div>
                        <div class="product-info flex-grow-1">
                            <h6><%= p.productName || 'Product' %></h6>
                            <span><%= p.unitsSold || 0 %> units sold</span>
                        </div>
                        <div class="product-stats">
                            <div class="product-price">$<%= typeof p.productPrice !== 'undefined' ? Number(p.productPrice).toLocaleString() : '0' %></div>
                        </div>
                    </div>
                    <% }); %>
                    <% if (products.length === 0) { %>
                    <div class="text-muted small py-3 text-center">No sales yet</div>
                    <% } %>
                    <div class="mt-3 text-center">
                        <a href="/seller/orders" class="small text-decoration-none fw-bold view-all-link">View All Products</a>
                    </div>

                </div>
            </div>
        </div>

    </div>
    
</div>

<%- include('includes/footer') %>