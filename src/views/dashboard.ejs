<%- include('includes/header') %>

<link rel="stylesheet" href="/css/dashboard.css">

<div class="container py-5">
    
    <%- include('includes/dashboard-header', {
        activeTab: 'overview',
        <!-- pageTitle: 'Overview', -->
        <!-- pageSubtitle: 'Track your sales and performance', -->
        user: user
    }) %>

    <div class="row g-3 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Total Revenue</span>
                    <i class="fa-solid fa-dollar-sign metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value">$12,450.00</h2>
                    <span class="trend-badge">
                        <i class="fa-solid fa-arrow-trend-up me-1"></i> 12%
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Total Orders</span>
                    <i class="fa-solid fa-cart-shopping metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value">145</h2>
                    <span class="trend-badge">
                        <i class="fa-solid fa-arrow-trend-up me-1"></i> 8.5%
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Products Listed</span>
                    <i class="fa-solid fa-box-archive metric-icon"></i>
                </div>
                <div class="mt-2">
                    <h2 class="metric-value">24</h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="metric-card d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="metric-label">Conversion Rate</span>
                    <i class="fa-solid fa-chart-pie metric-icon"></i>
                </div>
                <div class="d-flex align-items-baseline mt-2">
                    <h2 class="metric-value">3.2%</h2>
                    <span class="badge bg-light text-secondary border ms-2" style="font-size: 11px;">Avg</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="panel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="panel-title mb-0">Sales Overview</h5>
                    <select class="form-select form-select-sm w-auto border-0 bg-light">
                        <option>Last 30 Days</option>
                        <option>This Week</option>
                        <option>This Year</option>
                    </select>
                </div>
                
                <div class="chart-placeholder">
                    <div class="chart-line-mock"></div>
                    <div class="chart-bar" style="height: 40%;"></div>
                    <div class="chart-bar" style="height: 65%;"></div>
                    <div class="chart-bar" style="height: 50%;"></div>
                    <div class="chart-bar" style="height: 80%; background-color: #3c4257;"></div> 
                    <div class="chart-bar" style="height: 60%;"></div>
                    <div class="chart-bar" style="height: 75%;"></div>
                    <div class="chart-bar" style="height: 55%;"></div>
                </div>
                <div class="d-flex justify-content-between mt-3 text-muted small">
                    <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel">
                <h5 class="panel-title">Top Selling Products</h5>
                
                <div class="d-flex flex-column">
                    <div class="product-item">
                        <div class="product-thumb">
                            <i class="fa-solid fa-mobile-screen"></i>
                        </div>
                        <div class="product-info flex-grow-1">
                            <h6>iPhone 15 Pro</h6>
                            <span>24 units sold</span>
                        </div>
                        <div class="product-stats">
                            <div class="product-price">$999</div>
                        </div>
                    </div>

                    <div class="product-item">
                        <div class="product-thumb">
                            <i class="fa-solid fa-headphones"></i>
                        </div>
                        <div class="product-info flex-grow-1">
                            <h6>Sony WH-1000XM5</h6>
                            <span>18 units sold</span>
                        </div>
                        <div class="product-stats">
                            <div class="product-price">$349</div>
                        </div>
                    </div>

                    <div class="product-item">
                        <div class="product-thumb">
                            <i class="fa-solid fa-laptop"></i>
                        </div>
                        <div class="product-info flex-grow-1">
                            <h6>MacBook Air M2</h6>
                            <span>12 units sold</span>
                        </div>
                        <div class="product-stats">
                            <div class="product-price">$1,199</div>
                        </div>
                    </div>

                    <div class="product-item">
                        <div class="product-thumb">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                        <div class="product-info flex-grow-1">
                            <h6>Apple Watch S9</h6>
                            <span>9 units sold</span>
                        </div>
                        <div class="product-stats">
                            <div class="product-price">$399</div>
                        </div>
                    </div>
                    
                    <div class="mt-3 text-center">
                        <a href="/seller/products" class="small text-decoration-none fw-bold" style="color: var(--accent-blue);">View All Products</a>
                    </div>

                </div>
            </div>
        </div>

    </div>
    
</div>

<%- include('includes/footer') %>