<%- include('includes/header') %>

<link rel="stylesheet" href="/css/signup.css">

<div class="container py-5">
    <div class="row justify-content-center align-items-center">
        
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg overflow-hidden rounded-4">
                <div class="row g-0">

                    <div class="col-12 bg-white p-5">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold text-dark">Sign Up</h3>
                            <p class="text-muted">Enter your details to create an account</p>
                        </div>

                        <form action="/seller/signup" method="POST" enctype="multipart/form-data" onsubmit="return validateSignupForm()">
                            
                            <div class="mb-4 file-box">
                                <div class="text-center mb-3">
                                    <img src="/img/default-user.png" class="upload-img-frame rounded-circle" alt="avatar">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Upload Image</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0"><i class="fa-solid fa-image text-muted"></i></span>
                                        <input type="file" name="userImage" class="form-control border-start-0 upload-hidden user-image" required>
                                    </div>
                                    <input type="text" class="upload-name d-none">
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                                    <input type="text" name="userNick" class="form-control border-start-0 user-nick" placeholder="Steven" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                                    <input type="text" name="userPhone" class="form-control border-start-0 user-phone" placeholder="+998 90 123 45 67" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                                    <input type="password" name="userPassword" class="form-control border-start-0 user-password" placeholder="********" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Confirm Password</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="fa-solid fa-key text-muted"></i></span>
                                    <input type="password" name="confirm_password" class="form-control border-start-0 confirm-password" placeholder="********" required>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-outline-dark w-100 btn-lg fw-bold shadow-sm">
                                Sign Up
                            </button>

                            <div class="text-center mt-4">
                                <p class="text-muted">Already have an account? <a href="/seller/login" class="text-warning fw-bold text-decoration-none">Login</a></p>
                            </div>

                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(function () {
        const fileTarget = $(".file-box .upload-hidden");
        let filename;

        fileTarget.on("change", function () {
            if (window.FileReader) {
                const uploadFile = $(this)[0].files[0];
                if (!uploadFile) return;

                const fileType = uploadFile["type"];
                const validImageType = ["image/jpeg", "image/png", "image/jpg", "image/avif", "image/webp"];

                if (!validImageType.includes(fileType)) {
                    alert("Iltimos, faqat jpeg, jpg, avif, webp va png formatidagi rasmlarni yuklang!");
                    $(this).val(""); 
                } else {
                    if (uploadFile) {
                        // Rasmni PREVIEW qilish
                        $(".upload-img-frame")
                            .attr("src", URL.createObjectURL(uploadFile))
                            .addClass("success"); // CSS da yashil border uchun klass
                    }
                    filename = uploadFile.name;
                }
                $(this).siblings(".upload-name").val(filename);
            }
        });
    });

    function validateSignupForm() {
        const userNick = $(".user-nick").val();
        const userPhone = $(".user-phone").val();
        const userPassword = $(".user-password").val();
        const confirmPassword = $(".confirm-password").val();

        if (userNick === "" || userPhone === "" || userPassword === "" || confirmPassword === "") {
            alert("Iltimos, barcha maydonlarni to'ldiring!");
            return false;
        }

        if (userPassword !== confirmPassword) {
            alert("Parollar mos kelmadi, iltimos qayta tekshiring!");
            return false;
        }

        const userImage = $(".user-image").get(0).files[0];
        if (!userImage) {
            alert("Iltimos, rasmingizni yuklang!");
            return false;
        }

        return true;
    }
</script>

<%- include('includes/footer') %>