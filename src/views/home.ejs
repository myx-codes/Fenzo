<%- include('includes/header') %>

<div class="p-5 mb-5 bg-light rounded-3 shadow-sm border text-center">
  <div class="container py-5">
    <h1 class="display-5 fw-bold text-dark">
      Sell on Fenzo. Grow Your Business.
    </h1>
    <p class="col-md-8 fs-4 mx-auto text-muted mt-3">
      Fenzo is a modern online marketplace for sellers.
      List your products, receive orders, and earn revenue.
    </p>

    <div class="d-flex justify-content-center gap-3 mt-4">
      <a href="/seller/signup" class="btn  btn-outline-dark btn-lg px-4">
        Signup
      </a>
      <a href="/seller/login" class="btn  btn-outline-dark btn-lg px-4">
        Login
      </a>
    </div>
  </div>
</div>

<div class="row text-center mb-5">
  <div class="col-md-4 mb-4">
    <div class="card h-100 border-0 shadow-sm p-4">
      <i class="fa-solid fa-box-open fa-3x text-primary mb-3"></i>
      <h4>Easy Product Listing</h4>
      <p class="text-muted">
        List and manage your products in just a few minutes.
      </p>
    </div>
  </div>

  <div class="col-md-4 mb-4">
    <div class="card h-100 border-0 shadow-sm p-4">
      <i class="fa-solid fa-chart-line fa-3x text-success mb-3"></i>
      <h4>Sales & Analytics</h4>
      <p class="text-muted">
        Track orders, revenue, and statistics in real-time.
      </p>
    </div>
  </div>

  <div class="col-md-4 mb-4">
    <div class="card h-100 border-0 shadow-sm p-4">
      <i class="fa-solid fa-credit-card fa-3x text-warning mb-3"></i>
      <h4>Secure Payments</h4>
      <p class="text-muted">
        Payments are processed via a secure system and deposited into your balance.
      </p>
    </div>
  </div>
</div>

<div class="container py-5 mb-5">
    
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Why Choose Fenzo?</h2>
        <p class="text-muted fs-5">We are the fastest-growing marketplace in the region.</p>
    </div>

    <div class="row g-4">
        
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm py-4 text-center hover-scale" style="background: #f8f9fa;">
                <div class="card-body">
                    <div class="mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-store fa-2x"></i>
                        </span>
                    </div>
                    <h2 class="fw-bold mb-1 display-5 text-dark">1,200+</h2>
                    <p class="text-muted mb-0 fw-medium text-uppercase small">Active Sellers</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm py-4 text-center hover-scale" style="background: #f8f9fa;">
                <div class="card-body">
                    <div class="mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-users fa-2x"></i>
                        </span>
                    </div>
                    <h2 class="fw-bold mb-1 display-5 text-dark">55k+</h2>
                    <p class="text-muted mb-0 fw-medium text-uppercase small">Customers</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm py-4 text-center hover-scale" style="background: #f8f9fa;">
                <div class="card-body">
                    <div class="mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-boxes-stacked fa-2x"></i>
                        </span>
                    </div>
                    <h2 class="fw-bold mb-1 display-5 text-dark">150k+</h2>
                    <p class="text-muted mb-0 fw-medium text-uppercase small">Products Listed</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 shadow-sm py-4 text-center hover-scale" style="background: #f8f9fa;">
                <div class="card-body">
                    <div class="mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-truck-fast fa-2x"></i>
                        </span>
                    </div>
                    <h2 class="fw-bold mb-1 display-5 text-dark">2.5k+</h2>
                    <p class="text-muted mb-0 fw-medium text-uppercase small">Daily Orders</p>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="p-5 mb-5 bg-light rounded-3 shadow-sm border text-center">
  <h2 class="fw-bold mb-3">Start Selling Today</h2>
  <p class="mb-4">
    Thousands of sellers are growing their business through Fenzo.
  </p>
  <a href="/seller/signup" class="btn  btn-outline-dark btn-lg px-4">
    Create Seller Account
  </a>
</div>

<%- include('includes/footer') %>